# Render + Railway (Production) environment template
# Copy these keys into Render Environment Variables (do not commit real secrets)
# Backend (Render): https://smart-library-n8ze.onrender.com
# Frontend (Vercel): https://smart-library-eight.vercel.app/

# Server
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://smart-library-eight.vercel.app

# Railway MySQL
DB_HOST=your-railway-host
DB_PORT=3306
DB_USER=your-railway-user
DB_PASSWORD=your-railway-password
DB_NAME=railway

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# External integrations
AI_API_KEY=demo_key
SMS_API_KEY=demo_key
