PORT=5000
# PRODUCTION: Replace localhost with your production DB host.
DB_HOST=localhost
DB_USER=root
# PRODUCTION: Use a strong, secret DB password from secure secret storage.
DB_PASSWORD=your_password
DB_NAME=smart_library
# PRODUCTION: Use a long random JWT secret (never keep change_me).
JWT_SECRET=change_me
# PRODUCTION: Set real provider keys or disable related features.
SMS_API_KEY=demo_key
AI_API_KEY=demo_key
